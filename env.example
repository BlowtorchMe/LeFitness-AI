# Application Settings
APP_NAME=LE Fitness AI System
ENVIRONMENT=development
DEBUG=true

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Meta/Facebook Configuration (Optional in test mode)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_ACCESS_TOKEN=your_meta_access_token
META_VERIFY_TOKEN=your_webhook_verify_token

# Google Calendar Configuration (Optional - only needed for calendar features)
GOOGLE_CALENDAR_ID=
GOOGLE_CLIENT_CONFIG={"installed":{"client_id":"...","client_secret":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}}
# OR use service account (recommended for production)
GOOGLE_SERVICE_ACCOUNT=path/to/service-account.json
GOOGLE_API_KEY=your_google_api_key
TIMEZONE=UTC

# Email Configuration (Optional - Google Calendar sends emails automatically)
# Only needed if you want custom email templates
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=

# Twilio SMS Configuration (Optional - only needed for SMS features)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Database Configuration
# PostgreSQL (recommended for production)
# For local PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/lefitness
# For Supabase (cloud PostgreSQL - see SUPABASE_SETUP.md):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxxx.supabase.co:5432/postgres
# For SQLite (development only): DATABASE_URL=sqlite:///./lefitness.db
DATABASE_URL=postgresql://user:password@localhost:5432/lefitness

# Redis Configuration (for Celery task queue)
REDIS_URL=redis://localhost:6379/0

# Gym Information
GYM_NAME=LE Fitness
GYM_PHONE=
GYM_EMAIL=

# Free Trial Configuration
FREE_TRIAL_DAYS=10

# Testing/Mock Mode (set to true for testing without real APIs)
USE_MOCK_APIS=false
TEST_MODE=false

# Google Calendar Webhook URL (for push notifications)
# Set this to your public URL: https://yourdomain.com/webhooks/calendar
GOOGLE_CALENDAR_WEBHOOK_URL=https://yourdomain.com/webhooks/calendar


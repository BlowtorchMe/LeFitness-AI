# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Meta/Facebook Configuration
META_ACCESS_TOKEN=
META_VERIFY_TOKEN=test
META_APP_ID=
META_APP_SECRET=

# Local Database Configuration
#DATABASE_URL=postgresql://user:password@localhost:5432/lefitness

# Google Calendar Configuration
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com
GOOGLE_SERVICE_ACCOUNT=
GOOGLE_APPOINTMENT_SCHEDULE_LINK=https://calendar.app.google/your-schedule-id
GOOGLE_CALENDAR_WEBHOOK_URL=https://yourdomain.com/webhooks/calendar

# Gym Information
GYM_NAME=LE Fitness
GYM_EMAIL=

# Testing/Mock Mode
USE_MOCK_APIS=false
TEST_MODE=false

# Database Configuration (Docker)
#Fill POSTGRES_USER & POSTGRES_PASSWORD, then update DATABASE_URL + PG_CONN_STR to match.
DATABASE_URL=postgresql+psycopg://POSTGRES_USER:POSTGRES_PASSWORD@db:5432/lefitness_ai_backend
PG_CONN_STR=postgresql://POSTGRES_USER:POSTGRES_PASSWORD@db:5432/lefitness_ai_backend

# Postgres (Docker)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=lefitness_ai_backend

#pgAdmin4 (Docker)
PGADMIN_DEFAULT_EMAIL=
PGADMIN_DEFAULT_PASSWORD=
